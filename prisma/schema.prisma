generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum ResumeSourceType {
  text
  file
}

enum SearchProfileStatus {
  draft
  active
  archived
}

enum LearningObservationStatus {
  draft
  proposed
  accepted
  rejected
}

model UserSettings {
  id                  String   @id @default(cuid())
  aiProvider          String?
  aiBaseUrl           String?
  aiApiKey            String?
  aiPrimaryModel      String?
  aiFastModel         String?
  analysisProvider    String?
  analysisBaseUrl     String?
  analysisApiKey      String?
  analysisModel       String?
  fastModel           String?
  writerProvider      String?
  writerBaseUrl       String?
  writerApiKey        String?
  writerModel         String?
  reviewerModel       String?
  aiConfigured                  Boolean  @default(false)
  onboardingCompleted           Boolean  @default(false)
  salaryExpectationMin          Int?
  salaryExpectationMax          Int?
  salaryExpectationPreferredText String?
  salaryExpectationNet          Boolean? @default(true)
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt
}

model Resume {
  id             String           @id @default(cuid())
  title          String
  sourceType     ResumeSourceType
  sourceFileName String?
  originalText   String
  aiSummary      String?
  aiSummaryStale Boolean          @default(false)
  confirmedFacts String?
  isActive       Boolean          @default(false)
  isArchived     Boolean          @default(false)
  archivedAt     DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  applications   Application[]
  coverLetters   CoverLetter[]
  searchProfiles SearchProfile[]
}

model SearchProfile {
  id                  String              @id @default(cuid())
  resumeId            String
  title               String
  summary             String
  targetRolesJson     String
  searchQueriesJson   String
  positiveSignalsJson String
  negativeSignalsJson String
  stopWordsJson       String
  status              SearchProfileStatus @default(draft)
  isActive            Boolean             @default(false)
  archivedAt          DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  resume              Resume              @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  searchRuns          SearchRun[]
  vacancies           Vacancy[]
}

model Vacancy {
  id                      String         @id @default(cuid())
  searchProfileId         String?
  companyId               String?
  title                   String
  source                  String
  sourceUrl               String?
  sourceVacancyId         String?
  salaryText              String?
  location                String?
  workFormat              String?
  publishedAtText         String?
  employerUrl             String?
  isArchived              Boolean?
  rawDescription          String?
  status                  String
  matchScore              Int?
  employerScore           Int?
  finalScore              Int?
  aiAnalysisJson          String?
  redFlagsJson            String?
  matchReasonsJson        String?
  missingRequirementsJson String?
  recommendation          String?
  aiMetaJson              String?
  nextActionType          String?
  nextActionAt            DateTime?
  nextActionNote          String?
  testRequired            Boolean?
  testStatus              String?
  testLink                String?
  testNotes               String?
  testCompletedAt         DateTime?
  analysisErrorCode       String?
  analysisErrorMessage    String?
  skipReasonJson          String?
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt
  applications            Application[]
  company                 Company?       @relation(fields: [companyId], references: [id], onDelete: SetNull)
  coverLetters            CoverLetter[]
  interactions            Interaction[]
  searchRunItems          SearchRunItem[]
  searchProfile           SearchProfile? @relation(fields: [searchProfileId], references: [id], onDelete: SetNull)
}

model SearchRun {
  id              String          @id @default(cuid())
  searchProfileId String?
  status          String
  stage           String?
  currentQuery    String?
  currentQueryIndex Int?
  totalQueries    Int?
  progressJson    String?
  logJson         String?
  stopRequested   Boolean         @default(false)
  startedAt       DateTime        @default(now())
  finishedAt      DateTime?
  queriesJson     String
  totalFound      Int             @default(0)
  totalCreated    Int             @default(0)
  totalDuplicates Int             @default(0)
  totalAnalyzed       Int             @default(0)
  totalErrors         Int             @default(0)
  totalRecommended    Int             @default(0)
  totalAnalysisErrors Int             @default(0)
  totalCoverLetters   Int             @default(0)
  errorCode           String?
  errorMessage        String?
  errorLogJson        String?
  listHidden          Boolean         @default(false)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  searchProfile       SearchProfile?  @relation(fields: [searchProfileId], references: [id], onDelete: SetNull)
  items               SearchRunItem[]
}

model SearchRunItem {
  id          String    @id @default(cuid())
  searchRunId String
  vacancyId   String?
  sourceUrl   String
  status       String
  errorCode    String?
  errorMessage String?
  createdAt    DateTime  @default(now())
  searchRun    SearchRun @relation(fields: [searchRunId], references: [id], onDelete: Cascade)
  vacancy     Vacancy?  @relation(fields: [vacancyId], references: [id], onDelete: SetNull)
}

model AiCallLog {
  id               String    @id @default(cuid())
  taskType         String
  provider         String
  model            String
  role             String
  vacancyId        String?
  processRunId     String?
  inputTokens      Int?
  outputTokens     Int?
  totalTokens      Int?
  estimatedCostUsd Float?
  status           String
  errorCode        String?
  errorMessage     String?
  attemptNumber    Int?
  startedAt        DateTime?
  finishedAt       DateTime?
  durationMs       Int?
  createdAt        DateTime  @default(now())
}

model ProcessRun {
  id              String           @id @default(cuid())
  type            String
  status          String
  title           String
  description     String?
  progressCurrent Int              @default(0)
  progressTotal   Int              @default(0)
  progressPercent Int?
  currentStep     String?
  analysisMode    String?
  stopRequested   Boolean          @default(false)
  stoppedAt       DateTime?
  stoppedReason   String?
  listHidden      Boolean          @default(false)
  startedAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  finishedAt      DateTime?
  errorMessage    String?
  errorCode       String?
  resultJson      String?
  metadataJson    String?
  logs            ProcessLog[]
  items           ProcessRunItem[]
}

model ProcessRunItem {
  id           String     @id @default(cuid())
  processRunId String
  vacancyId    String?
  status       String
  title        String
  errorCode    String?
  errorMessage String?
  startedAt    DateTime?
  finishedAt   DateTime?
  durationMs   Int?
  processRun   ProcessRun @relation(fields: [processRunId], references: [id], onDelete: Cascade)
}

model ProcessLog {
  id           String     @id @default(cuid())
  processRunId String
  level        String
  message      String
  detailsJson  String?
  createdAt    DateTime   @default(now())
  processRun   ProcessRun @relation(fields: [processRunId], references: [id], onDelete: Cascade)
}

model Company {
  id            String        @id @default(cuid())
  name          String
  brandName     String?
  inn           String?
  ogrn          String?
  website       String?
  employerScore Int?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  interactions  Interaction[]
  vacancies     Vacancy[]
}

model Application {
  id            String        @id @default(cuid())
  vacancyId     String
  resumeId      String?
  coverLetterId String?
  status        String
  appliedAt     DateTime?
  responseAt    DateTime?
  nextActionAt  DateTime?
  outcome       String?
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  coverLetter   CoverLetter?  @relation(fields: [coverLetterId], references: [id], onDelete: SetNull)
  interactions  Interaction[]
  resume        Resume?       @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  vacancy       Vacancy       @relation(fields: [vacancyId], references: [id], onDelete: Cascade)
}

model CoverLetter {
  id           String        @id @default(cuid())
  vacancyId    String
  resumeId     String
  text         String
  style        String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  applications Application[]
  resume       Resume        @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  vacancy      Vacancy       @relation(fields: [vacancyId], references: [id], onDelete: Cascade)
}

model Interaction {
  id            String       @id @default(cuid())
  applicationId String?
  companyId     String?
  vacancyId     String?
  type          String
  occurredAt    DateTime
  summary       String
  rawText       String?
  aiSummary     String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  application   Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  company       Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  vacancy       Vacancy?     @relation(fields: [vacancyId], references: [id], onDelete: SetNull)
}

model LearningObservation {
  id            String                    @id @default(cuid())
  sourceType    String
  sourceId      String?
  description   String
  evidenceJson  String
  suggestedRule String?
  status        LearningObservationStatus @default(draft)
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
}
